{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-push-check.sh",
            "timeout": 120,
            "statusMessage": "Running cargo fmt + clippy before push..."
          }
        ]
      }
    ]
  }
}
