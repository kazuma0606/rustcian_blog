# ── Server ──────────────────────────────────────────────────────────────────
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8080
BASE_URL=http://127.0.0.1:8080

# ── Content ──────────────────────────────────────────────────────────────────
CONTENT_ROOT=./content

# ── Storage (local | azurite) ────────────────────────────────────────────────
STORAGE_BACKEND=azurite
AZURITE_BLOB_ENDPOINT=http://127.0.0.1:10000/devstoreaccount1
AZURITE_TABLE_ENDPOINT=http://127.0.0.1:10002/devstoreaccount1

# ── Static site output ───────────────────────────────────────────────────────
# STATIC_OUTPUT_DIR=./dist
# STATIC_PUBLISH_BACKEND=local    # local | azurite
# STATIC_PUBLISH_PREFIX=site

# ── Admin auth (disabled | local-dev | entra) ────────────────────────────────
ADMIN_AUTH_MODE=disabled
# ADMIN_AUTH_MODE=local-dev       # HTTP Basic (admin / changeme)
# ADMIN_AUTH_MODE=entra
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_OIDC_METADATA_URL=https://login.microsoftonline.com/<tenant>/v2.0/.well-known/openid-configuration
# ENTRA_ADMIN_GROUP_ID=
# ENTRA_ADMIN_USER_OID=
# ENTRA_REDIRECT_URI=https://rustacian-blog.com/admin/callback

# ── Azure OpenAI (AI metadata generation) ───────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_MODEL_NAME=gpt-4o-mini
# AZURE_OPENAI_API_KEY=

# ── Observability (stdout | appinsights | noop) ──────────────────────────────
OBSERVABILITY_BACKEND=stdout
# OBSERVABILITY_BACKEND=appinsights
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=https://...;

# ── Slack notifications ──────────────────────────────────────────────────────
# Leave empty to disable (NoopNotificationSink will be used)
SLACK_WEBHOOK_URL=

# ── Cloudflare cache purge ────────────────────────────────────────────────────
# Purge all cached files after static site publish. Leave empty to skip.
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=
